# Root .gitignore for Vela project
# ------------------------------

# Dependency directories
node_modules/
frontend/node_modules/
backend/.venv/
backend/venv/
.venv/
venv/

# Build outputs
frontend/.next/
frontend/out/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
backend/.env*
**/.env*

# Sensitive credentials
**/*service-account.json
**/firebase-service-account.json
**/*.pem
**/*.key

# Platform specific files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip-delete-this-directory.txt

# Testing
coverage/
frontend/coverage/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
